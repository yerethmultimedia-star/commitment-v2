{
  "extends": "@commitment/config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["DOM", "ES2022"],
    "jsx": "react-jsx",
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
